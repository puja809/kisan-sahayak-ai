# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=indian_farmer_app
MONGODB_COLLECTION_DOCUMENTS=documents

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Microservices MCP Endpoints (Comma separated for Bedrock LangChain Agent)
# In ECS, override this string with the internal Service Discovery URLs or ALB.
MCP_ENDPOINTS=http://localhost:8082/mcp/sse,http://localhost:8083/mcp/sse,http://localhost:8084/mcp/sse,http://localhost:8085/mcp/sse,http://localhost:8086/mcp/sse,http://localhost:8087/mcp/sse

# AWS API Gateway Endpoints
AWS_API_TEXT_ENDPOINT=https://5m2acu2lea.execute-api.us-east-1.amazonaws.com/prod/ask
AWS_API_VOICE_ENDPOINT=https://5m2acu2lea.execute-api.us-east-1.amazonaws.com/prod/ask-voice
AWS_API_STREAM_TEXT_ENDPOINT=https://5m2acu2lea.execute-api.us-east-1.amazonaws.com/prod/ask/stream
AWS_API_STREAM_VOICE_ENDPOINT=https://5m2acu2lea.execute-api.us-east-1.amazonaws.com/prod/ask-voice/stream
AWS_API_DETECT_DISEASE_ENDPOINT=https://5m2acu2lea.execute-api.us-east-1.amazonaws.com/prod/detect-disease

# Vector Database Configuration
VECTOR_DIMENSION=768
VECTOR_SIMILARITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=10

# Logging Configuration
LOG_LEVEL=INFO